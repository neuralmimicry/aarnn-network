    {
      "mode": "managed",
      "type": "local_file",
      "name": "aeron_dockerfile_k8s",
      "provider": "provider[\"registry.terraform.io/hashicorp/local\"]",
      "instances": [
        {
          "index_key": 0,
          "schema_version": 0,
          "attributes": {
            "content": "# syntax=docker/dockerfile:1.7-labs\n# Multi-stage build for Aeron\n\nFROM eclipse-temurin:21-jdk AS build\n\n# Install required tools\nRUN apt-get update \u0026\u0026 apt-get install -y --no-install-recommends \\\n    git maven ca-certificates curl \u0026\u0026 \\\n    rm -rf /var/lib/apt/lists/*\n\nWORKDIR /src\n\n# Clone specific ref for Aeron\nARG AERON_REF=\"master\"\nRUN --mount=type=cache,target=/root/.m2 \\\n    git clone https://github.com/aeron-io/aeron.git \u0026\u0026 \\\n    cd aeron \u0026\u0026 \\\n    git fetch --all --tags \u0026\u0026 \\\n    git checkout \"$AERON_REF\" \u0026\u0026 \\\n    ./gradlew --no-daemon :aeron-all:build \u0026\u0026 \\\n    mkdir -p /out \u0026\u0026 \\\n    cp ./aeron-all/build/libs/aeron-all-*.jar /out/aeron-all.jar || \\\n    { echo \"Falling back to maven build\"; mvn -q -DskipTests package; cp ./aeron-all/target/aeron-all-*.jar /out/aeron-all.jar; }\n\nFROM eclipse-temurin:21-jre AS runtime\nLABEL org.opencontainers.image.source=\"https://github.com/aeron-io/aeron\" \\\n      org.opencontainers.image.description=\"Aeron runtime with Media Driver\"\n\nRUN apt-get update \u0026\u0026 apt-get install -y --no-install-recommends bash ca-certificates \u0026\u0026 rm -rf /var/lib/apt/lists/*\n\nWORKDIR /\nCOPY --from=build /out/aeron-all.jar /aeron/aeron-all.jar\n\n# Default command can be overridden by container definition\nENTRYPOINT [\"bash\", \"-lc\"]\nCMD [\"java\", \"--add-exports=java.base/jdk.internal.misc=ALL-UNNAMED\", \"-cp\", \"/aeron/aeron-all.jar\", \"io.aeron.driver.MediaDriver\"]\n",
            "content_base64": null,
            "content_base64sha256": "8qGdvSnRumqsWEde589xgN3BbHmtEPIp9TFUkESF+zQ=",
            "content_base64sha512": "2tFTqycXfVGoARVx2mUsFa0wTeR6PpmbJR8KTp8hEF0+PZ4UCB23vWjOxNPROTl9sCPNHjierz95Aw/6u1sxFg==",
            "content_md5": "61a957da512bc3b38c2a7375ff3eccbf",
