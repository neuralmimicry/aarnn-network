    {
      "module": "module.local_apps",
      "mode": "managed",
      "type": "local_file",
      "name": "aarnn_dockerfile",
      "provider": "provider[\"registry.terraform.io/hashicorp/local\"]",
      "instances": [
        {
          "index_key": 0,
          "schema_version": 0,
          "attributes": {
            "content": "# syntax=docker/dockerfile:1.7-labs\n# Multi-stage build for AARNN (C++) on Debian Bookworm\n\nFROM debian:bookworm-slim AS build\n\nENV DEBIAN_FRONTEND=noninteractive\n\n# Install build toolchain and libs\nRUN set -eux; \\\n    echo \"deb http://deb.debian.org/debian bookworm-backports main\" \u003e /etc/apt/sources.list.d/backports.list; \\\n    apt-get update; \\\n    apt-get install -y --no-install-recommends ca-certificates curl gnupg wget; \\\n    install -d -m 0755 /etc/apt/keyrings; \\\n    curl -fsSL https://apt.kitware.com/keys/kitware-archive-latest.asc | gpg --dearmor -o /etc/apt/keyrings/kitware-archive-keyring.gpg; \\\n    echo \"deb [signed-by=/etc/apt/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/debian/ bookworm main\" \u003e /etc/apt/sources.list.d/kitware.list; \\\n    apt-get update; \\\n    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \\\n      git build-essential ninja-build pkg-config \\\n      cmake \\\n      # Core/libs\n      libssl-dev libcurl4-openssl-dev libgmp-dev libfftw3-dev \\\n      libpq-dev libpqxx-dev \\\n      # Boost from backports (for Boost.JSON component)\n      -t bookworm-backports libboost-all-dev \\\n      # OpenCV\n      libopencv-dev \\\n      # Graphics/GL/Viz\n      libgl1-mesa-dev libglu1-mesa-dev freeglut3-dev libglew-dev libfreetype6-dev libopengl-dev \\\n      # VTK\n      libvtk9-dev \\\n      # MPI\n      libopenmpi-dev \\\n      # Audio\n      libasound2-dev portaudio19-dev libpulse-dev libsndfile1-dev \\\n      # FFmpeg\n      libavcodec-dev libavformat-dev libavutil-dev libswscale-dev libswresample-dev \\\n      # GStreamer\n      libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev gstreamer1.0-plugins-base gstreamer1.0-plugins-good \\\n      # Other utilities\n      wget ca-certificates; \\\n    rm -rf /var/lib/apt/lists/*\n\nWORKDIR /app\n\n# Copy local repo into the image (build context should be repository root)\nCOPY . /app/\n\n# Build AARNN and optionally Visualiser\nRUN set -eux; \\\n    cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Release; \\\n    cmake --build build --target AARNN -j; \\\n    # Build Visualiser as well when VTK is available; ignore failure to keep image useful\n    (cmake --build build --target Visualiser -j || true); \\\n    cmake --install build --component Unspecified || true\n\nFROM debian:bookworm-slim AS runtime\nLABEL org.opencontainers.image.source=\"https://github.com/neuralmimicry/aarnn\" \\\n      org.opencontainers.image.description=\"AARNN runtime (Debian Bookworm)\"\n\nRUN set -eux; \\\n    apt-get update; \\\n    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \\\n      # Runtime libs matching links\n      libssl3 libcurl4 libgmp10 libfftw3-3 \\\n      libpq5 libpqxx-7 \\\n      libboost-filesystem1.74.0 libboost-system1.74.0 libboost-json1.74.0 \\\n      libopencv-core406 libopencv-imgproc406 libopencv-highgui406 || true; \\\n    # Fallback: if specific versions unavailable, install metapackage\n    apt-get -y install --no-install-recommends libopencv-dev || true; \\\n    apt-get install -y --no-install-recommends \\\n      libgl1 libglx-mesa0 libgl1-mesa-dri libglu1-mesa freeglut3 libglew2.2 libfreetype6 \\\n      libvtk9.1 \\\n      libasound2 libportaudio2 libpulse0 libsndfile1 \\\n      libavcodec59 libavformat59 libavutil57 libswscale6 libswresample4 \\\n      libgstreamer1.0-0 libgstreamer-plugins-base1.0-0 \\\n      ca-certificates bash; \\\n    rm -rf /var/lib/apt/lists/*\n\nWORKDIR /app\n\n# Copy built binaries and default configs\nCOPY --from=build /app/build/AARNN /app/AARNN\n# Visualiser may or may not exist\nCOPY --from=build /app/build/Visualiser /app/Visualiser 2\u003e/dev/null || true\nCOPY configure/simulation.conf /app/simulation.conf\nCOPY configure/Visualiser.conf /app/Visualiser.conf\n\n# Default command runs the AARNN simulator; override to run Visualiser\nENTRYPOINT [\"/bin/bash\", \"-lc\"]\nCMD [\"/app/AARNN\"]\n",
            "content_base64": null,
            "content_base64sha256": "DUgCjP3+6v9sPNxYwyFGOZWO1cC2tCIFrIpFEZByiK0=",
            "content_base64sha512": "UnWgupXHxSQbuzgxxXKI850vp+M4iHg5xFkgsmU98r/rPtBOBUhrWsS2TTYP+u8lvIBhPGOlwbunTzhlggymtA==",
            "content_md5": "f82802e3a4d4ea18b6dbf5e70f1539e0",
            "content_sha1": "6c17ed44eefc86ce5e16c1d03d9a4465040d3e2b",
            "content_sha256": "0d48028cfdfeeaff6c3cdc58c3214639958ed5c0b6b42205ac8a4511907288ad",
            "content_sha512": "5275a0ba95c7c5241bbb3831c57288f39d2fa7e338887839c45920b2653df2bfeb3ed04e05486b5ac4b64d360ffaef25bc80613c63a5c1bba74f3865820ca6b4",
            "directory_permission": "0777",
            "file_permission": "0777",
            "filename": "modules/local-apps/.generated/Dockerfile.aarnn",
            "id": "6c17ed44eefc86ce5e16c1d03d9a4465040d3e2b",
