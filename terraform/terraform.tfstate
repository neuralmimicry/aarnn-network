          "schema_version": 0,
          "attributes": {
            "content": "    global:\n      scrape_interval: 15s\n      evaluation_interval: 15s\n\n    scrape_configs:\n      - job_name: 'prometheus'\n        static_configs:\n          - targets: ['aarnn-net-prometheus:9090']\n\n      - job_name: 'aarnn'\n        metrics_path: /metrics\n        static_configs:\n          - targets: ['aarnn-net-aarnn:8080']\n\n      - job_name: 'aeron'\n        static_configs:\n          - targets: [] # Aeron does not expose Prometheus metrics by default\n",
            "content_base64": null,
