    {
      "mode": "managed",
      "type": "local_file",
      "name": "aarnn_dockerfile_k8s",
      "provider": "provider[\"registry.terraform.io/hashicorp/local\"]",
      "instances": [
        {
          "index_key": 0,
          "schema_version": 0,
          "attributes": {
            "content": "# syntax=docker/dockerfile:1.7-labs\n# Kubernetes-local build for AARNN (C++) using Ubuntu 22.04 build base\n# - Full developer libraries installed (Boost, OpenCV, VTK, OpenMPI, FFmpeg, GStreamer, Audio)\n# - Robust apt retries to mitigate transient mirror issues\n# - Clones upstream repo at the requested ref, builds with CMake/Make\n# - Ships a tiny fallback HTTP server serving /health on :8080\n\nFROM ubuntu:22.04 AS build\n\nENV DEBIAN_FRONTEND=noninteractive\n\n# Install full toolchain + developer libraries with retries\nRUN set -eux; \\\n    apt-get -o Acquire::Retries=3 update; \\\n    # Base tools and certs\n    apt-get install -y --no-install-recommends \\\n      ca-certificates curl wget gnupg software-properties-common \\\n      build-essential ninja-build pkg-config cmake git; \\\n    # Core/common libs\n    apt-get -o Acquire::Retries=3 install -y --no-install-recommends \\\n      libssl-dev libcurl4-openssl-dev libgmp-dev libfftw3-dev \\\n      libpq-dev libpqxx-dev; \\\n    # Boost (Ubuntu jammy provides 1.74 with Boost.JSON headers)\n    apt-get -o Acquire::Retries=3 install -y --no-install-recommends libboost-all-dev; \\\n    # OpenCV\n    apt-get -o Acquire::Retries=3 install -y --no-install-recommends libopencv-dev; \\\n    # Graphics/GL/Viz\n    apt-get -o Acquire::Retries=3 install -y --no-install-recommends \\\n      libgl1-mesa-dev libglu1-mesa-dev freeglut3-dev libglew-dev libfreetype6-dev; \\\n    # VTK + MPI\n    apt-get -o Acquire::Retries=3 install -y --no-install-recommends libvtk9-dev libopenmpi-dev; \\\n    # Audio\n    apt-get -o Acquire::Retries=3 install -y --no-install-recommends \\\n      libasound2-dev portaudio19-dev libpulse-dev libsndfile1-dev; \\\n    # FFmpeg\n    apt-get -o Acquire::Retries=3 install -y --no-install-recommends \\\n      libavcodec-dev libavformat-dev libavutil-dev libswscale-dev libswresample-dev; \\\n    # GStreamer\n    apt-get -o Acquire::Retries=3 install -y --no-install-recommends \\\n      libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev gstreamer1.0-plugins-base gstreamer1.0-plugins-good; \\\n    # Cleanup lists to keep layer smaller\n    rm -rf /var/lib/apt/lists/*\n\nWORKDIR /src\n\n# Clone upstream AARNN at the requested ref with fallbacks\nARG AARNN_REF=\"main\"\nRUN set -eux; \\\n    rm -rf /tmp/aarnn /tmp/aarnn-src || true; \\\n    success=0; \\\n    for i in 1 2 3; do \\\n      git clone --depth 1 --branch \"$AARNN_REF\" https://github.com/neuralmimicry/aarnn.git /tmp/aarnn \u0026\u0026 success=1 \u0026\u0026 break || sleep 2; \\\n    done; \\\n    if [ \"$success\" -eq 1 ]; then \\\n      cp -a /tmp/aarnn/. /src/; \\\n    else \\\n      for i in 1 2 3; do \\\n        git clone https://github.com/neuralmimicry/aarnn.git /tmp/aarnn \u0026\u0026 break || sleep 2; \\\n      done; \\\n      if [ -d /tmp/aarnn/.git ]; then \\\n        cd /tmp/aarnn \u0026\u0026 git fetch --all --tags || true; \\\n        (git checkout \"$AARNN_REF\" || true); \\\n        cp -a /tmp/aarnn/. /src/; \\\n      fi; \\\n    fi; \\\n    if [ ! -f /src/CMakeLists.txt ]; then \\\n      echo \"Git clone failed or missing CMakeLists; attempting tarball\"; \\\n      mkdir -p /tmp/aarnn-src; \\\n      success_tar=0; \\\n      for i in 1 2 3; do \\\n        if curl -fsSL -o /tmp/aarnn.tar.gz \"https://codeload.github.com/neuralmimicry/aarnn/tar.gz/refs/heads/$AARNN_REF\"; then success_tar=1; break; fi; \\\n        sleep 2; \\\n      done; \\\n      if [ \"$success_tar\" -ne 1 ]; then \\\n        for i in 1 2 3; do \\\n          if curl -fsSL -o /tmp/aarnn.tar.gz \"https://codeload.github.com/neuralmimicry/aarnn/tar.gz/$AARNN_REF\"; then success_tar=1; break; fi; \\\n          sleep 2; \\\n        done; \\\n      fi; \\\n      if [ \"$success_tar\" -eq 1 ] \u0026\u0026 [ -s /tmp/aarnn.tar.gz ]; then \\\n        tar -xzf /tmp/aarnn.tar.gz -C /tmp/aarnn-src --strip-components=1 || true; \\\n        cp -a /tmp/aarnn-src/. /src/ || true; \\\n      else \\\n        echo \"Tarball fetch failed; proceeding without upstream sources\"; \\\n      fi; \\\n    fi\n\n# Build with CMake (Ninja if available), fallback to Make; always ensure build dir exists\nRUN set -eux; \\\n    if [ -f CMakeLists.txt ]; then \\\n      cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Release || cmake -S . -B build -DCMAKE_BUILD_TYPE=Release; \\\n      cmake --build build -j || cmake --build build; \\\n      (cmake --install build || true); \\\n    elif [ -f Makefile ] || [ -f makefile ]; then \\\n      make -j\"$(nproc)\" || make; \\\n    else \\\n      echo \"No C++ build metadata found (CMake/Make). Proceeding without building.\"; \\\n    fi; \\\n    mkdir -p /src/build\n\n# Tiny fallback HTTP health server on :8080 serving /health\nRUN \u003c\u003c'CPP' g++ -O2 -s -o /usr/local/bin/health_server -x c++ -\n#include \u003carpa/inet.h\u003e\n#include \u003cnetinet/in.h\u003e\n#include \u003csys/socket.h\u003e\n#include \u003cunistd.h\u003e\n#include \u003ccstring\u003e\n#include \u003cstring\u003e\nint main(){\n  int s = socket(AF_INET, SOCK_STREAM, 0); int opt=1; setsockopt(s,SOL_SOCKET,SO_REUSEADDR,\u0026opt,sizeof(opt));\n  sockaddr_in addr{}; addr.sin_family=AF_INET; addr.sin_addr.s_addr=INADDR_ANY; addr.sin_port=htons(8080);\n  if(bind(s,(sockaddr*)\u0026addr,sizeof(addr))\u003c0) return 1; if(listen(s,16)\u003c0) return 1;\n  while(true){ int c=accept(s,nullptr,nullptr); if(c\u003c0) continue; char buf[1024]; ssize_t n=read(c,buf,sizeof(buf)-1); if(n\u003c0) n=0; buf[n]=0;\n    std::string req(buf); bool ok = req.find(\" /health \")!=std::string::npos || req.find(\" /health?\")!=std::string::npos || req.rfind(\"GET /health\",0)==0;\n    const char* resp = ok ? \"HTTP/1.1 200 OK\\r\\nContent-Length: 2\\r\\nContent-Type: text/plain\\r\\nConnection: close\\r\\n\\r\\nOK\"\n                           : \"HTTP/1.1 404 Not Found\\r\\nContent-Length: 9\\r\\nContent-Type: text/plain\\r\\nConnection: close\\r\\n\\r\\nNot Found\";\n    write(c, resp, strlen(resp)); close(c);\n  }\n}\nCPP\n\nFROM ubuntu:22.04 AS runtime\nLABEL org.opencontainers.image.source=\"https://github.com/neuralmimicry/aarnn\" \\\n      org.opencontainers.image.description=\"AARNN C++ runtime with fallback health endpoint\"\n\nRUN apt-get -o Acquire::Retries=3 update \u0026\u0026 apt-get install -y --no-install-recommends \\\n    ca-certificates bash curl \u0026\u0026 \\\n    rm -rf /var/lib/apt/lists/*\n\n# Copy built artifacts (if any) and the fallback health server\nWORKDIR /app\nCOPY --from=build /src/build /app/build\nCOPY --from=build /src /app/src\nCOPY --from=build /usr/local/bin/health_server /usr/local/bin/health_server\n\nEXPOSE 8080\n\n# Default: run fallback health server; override CMD to run the actual AARNN binary if known\nENTRYPOINT [\"bash\", \"-lc\"]\nCMD [\"/usr/local/bin/health_server\"]\n",
            "content_base64": null,
            "content_base64sha256": "cR/4OiE4HfAlGnNElfscma3+lv5eProhnI6ITfkYga4=",
            "content_base64sha512": "th1QXxxl0NIWjF/E/gz8W5vp+68Sc0HaxIyXf8/YqmHHgdzc8zDMy2wveb3cv9NgUxg1Miu+51Mp1Wtu9ZYcOA==",
            "content_md5": "ddfb1f7fb542ec19d886e1d5a077dd39",
            "content_sha1": "ba4ad8a6f91072ee6b89e619939d4cb6e0d2a27d",
            "content_sha256": "711ff83a21381df0251a734495fb1c99adfe96fe5e3eba219c8e884df91881ae",
            "content_sha512": "b61d505f1c65d0d2168c5fc4fe0cfc5b9be9fbaf127341dac48c977fcfd8aa61c781dcdcf330cccb6c2f79bddcbfd360531835322bbee75329d56b6ef5961c38",
            "directory_permission": "0777",
