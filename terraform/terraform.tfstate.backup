    {
      "module": "module.local_apps",
      "mode": "managed",
      "type": "local_file",
      "name": "aarnn_dockerfile",
      "provider": "provider[\"registry.terraform.io/hashicorp/local\"]",
      "instances": [
        {
          "index_key": 0,
          "schema_version": 0,
          "attributes": {
            "content": "# syntax=docker/dockerfile:1.7-labs\n# Multi-stage build for AARNN (C++)\n\nFROM debian:bookworm-slim AS build\n\nENV DEBIAN_FRONTEND=noninteractive\n\n# Install build toolchain and utilities + enable backports and Kitware APT for newer CMake\nRUN set -eux; \\\n    echo \"deb http://deb.debian.org/debian bookworm-backports main\" \u003e /etc/apt/sources.list.d/backports.list; \\\n    apt-get update; \\\n    apt-get install -y --no-install-recommends ca-certificates curl gnupg wget; \\\n    install -d -m 0755 /etc/apt/keyrings; \\\n    curl -fsSL https://apt.kitware.com/keys/kitware-archive-latest.asc | gpg --dearmor -o /etc/apt/keyrings/kitware-archive-keyring.gpg; \\\n    echo \"deb [signed-by=/etc/apt/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/debian/ bookworm main\" \u003e /etc/apt/sources.list.d/kitware.list; \\\n    apt-get update; \\\n    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \\\n      git build-essential ninja-build pkg-config \\\n      cmake \\\n      # Core/libs\n      libssl-dev libcurl4-openssl-dev libgmp-dev libfftw3-dev \\\n      libpq-dev libpqxx-dev \\\n      # Boost from backports to ensure Boost.JSON availability\n      -t bookworm-backports libboost-all-dev \\\n      # OpenCV\n      libopencv-dev \\\n      # Graphics/GL/Viz\n      libgl1-mesa-dev libglu1-mesa-dev freeglut3-dev libglew-dev libfreetype6-dev libopengl-dev \\\n      # VTK\n      libvtk9-dev \\\n      # MPI\n      libopenmpi-dev \\\n      # Audio\n      libasound2-dev portaudio19-dev libpulse-dev libsndfile1-dev \\\n      # FFmpeg\n      libavcodec-dev libavformat-dev libavutil-dev libswscale-dev libswresample-dev \\\n      # GStreamer\n      libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev gstreamer1.0-plugins-base gstreamer1.0-plugins-good \\\n      # Other utilities\n      wget ca-certificates; \\\n    rm -rf /var/lib/apt/lists/*\n\n# Ensure CMake and pkg-config can discover config files\nENV CMAKE_PREFIX_PATH=\"/usr/lib/x86_64-linux-gnu/cmake:/usr/lib/cmake:${CMAKE_PREFIX_PATH}\"\nENV PKG_CONFIG_PATH=\"/usr/lib/x86_64-linux-gnu/pkgconfig:/usr/lib/pkgconfig:${PKG_CONFIG_PATH}\"\n\nWORKDIR /src\n\n# Clone the specified ref of AARNN\nARG AARNN_REF=\"main\"\n# Robust fetch of AARNN source with multiple fallbacks:\n# 1) Shallow clone by ref into temp then copy into /src\n# 2) Full clone + checkout ref\n# 3) Download tarball for ref/commit and extract\nRUN set -eux; \\\n    rm -rf /tmp/aarnn /tmp/aarnn-src || true; \\\n    success=0; \\\n    for i in 1 2 3; do \\\n      git clone --depth 1 --branch \"$AARNN_REF\" https://github.com/neuralmimicry/aarnn.git /tmp/aarnn \u0026\u0026 success=1 \u0026\u0026 break || sleep 2; \\\n    done; \\\n    if [ \"$success\" -eq 1 ]; then \\\n      cp -a /tmp/aarnn/. /src/; \\\n    else \\\n      for i in 1 2 3; do \\\n        git clone https://github.com/neuralmimicry/aarnn.git /tmp/aarnn \u0026\u0026 break || sleep 2; \\\n      done; \\\n      if [ -d /tmp/aarnn/.git ]; then \\\n        cd /tmp/aarnn \u0026\u0026 git fetch --all --tags || true; \\\n        (git checkout \"$AARNN_REF\" || true); \\\n        cp -a /tmp/aarnn/. /src/; \\\n      fi; \\\n    fi; \\\n    if [ ! -f /src/README.md ]; then \\\n      echo \"Git clone failed; attempting tarball download\"; \\\n      mkdir -p /tmp/aarnn-src; \\\n      (curl -fsSL -o /tmp/aarnn.tar.gz \"https://codeload.github.com/neuralmimicry/aarnn/tar.gz/refs/heads/${AARNN_REF}\" || \\\n       curl -fsSL -o /tmp/aarnn.tar.gz \"https://codeload.github.com/neuralmimicry/aarnn/tar.gz/${AARNN_REF}\") \u0026\u0026 \\\n       tar -xzf /tmp/aarnn.tar.gz -C /tmp/aarnn-src --strip-components=1 \u0026\u0026 \\\n       cp -a /tmp/aarnn-src/. /src/ || true; \\\n    fi\n\n# Attempt to build using CMake (Ninja first), fallback to Makefile if present\n# Artifacts are left in /src/build (if CMake) or /src (if Makefile)\nRUN set -eux; \\\n    if [ -f CMakeLists.txt ]; then \\\n      cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Release || cmake -S . -B build -DCMAKE_BUILD_TYPE=Release; \\\n      cmake --build build -j || cmake --build build; \\\n      (cmake --install build || true); \\\n    elif [ -f Makefile ] || [ -f makefile ]; then \\\n      make -j\"$(nproc)\" || make; \\\n    else \\\n      echo \"No C++ build metadata found (CMake/Make). Proceeding without building.\"; \\\n    fi \\\n    \u0026\u0026 mkdir -p /src/build\n\n# Build a tiny fallback C++ health server that serves /health on :8080\nRUN \u003c\u003c'CPP' g++ -O2 -s -o /usr/local/bin/health_server -x c++ -\n#include \u003carpa/inet.h\u003e\n#include \u003cnetinet/in.h\u003e\n#include \u003csys/socket.h\u003e\n#include \u003cunistd.h\u003e\n#include \u003ccstring\u003e\n#include \u003cstring\u003e\n#include \u003ciostream\u003e\nint main(){\n  int s = socket(AF_INET, SOCK_STREAM, 0);\n  int opt=1; setsockopt(s, SOL_SOCKET, SO_REUSEADDR, \u0026opt, sizeof(opt));\n  sockaddr_in addr{}; addr.sin_family=AF_INET; addr.sin_addr.s_addr=INADDR_ANY; addr.sin_port=htons(8080);\n  if(bind(s,(sockaddr*)\u0026addr,sizeof(addr))\u003c0) return 1; if(listen(s,16)\u003c0) return 1;\n  while(true){ int c=accept(s,nullptr,nullptr); if(c\u003c0) continue; char buf[1024]; ssize_t n=read(c,buf,sizeof(buf)-1); if(n\u003c0) n=0; buf[n]=0; \n    std::string req(buf); bool ok = req.find(\" /health \")!=std::string::npos || req.find(\" /health?\")!=std::string::npos || req.rfind(\"GET /health\",0)==0; \n    const char* resp = ok ? \"HTTP/1.1 200 OK\\r\\nContent-Length: 2\\r\\nContent-Type: text/plain\\r\\nConnection: close\\r\\n\\r\\nOK\"\n                          : \"HTTP/1.1 404 Not Found\\r\\nContent-Length: 9\\r\\nContent-Type: text/plain\\r\\nConnection: close\\r\\n\\r\\nNot Found\";\n    write(c, resp, strlen(resp)); close(c);\n  }\n}\nCPP\n\nFROM debian:bookworm-slim AS runtime\nLABEL org.opencontainers.image.source=\"https://github.com/neuralmimicry/aarnn\" \\\n      org.opencontainers.image.description=\"AARNN C++ runtime with fallback health endpoint\"\n\nRUN apt-get update \u0026\u0026 apt-get install -y --no-install-recommends \\\n    ca-certificates bash curl \u0026\u0026 \\\n    rm -rf /var/lib/apt/lists/*\n\n# Copy built artifacts if any\nCOPY --from=build /src/build /app/build\nCOPY --from=build /src /app/src\nCOPY --from=build /usr/local/bin/health_server /usr/local/bin/health_server\n\nWORKDIR /app\nEXPOSE 8080\n\n# Default: run fallback health server; override CMD to run the actual AARNN binary if known\nENTRYPOINT [\"bash\", \"-lc\"]\nCMD [\"/usr/local/bin/health_server\"]\n",
            "content_base64": null,
            "content_base64sha256": "2wZ2LruueRFfGt0hpGyLKB80ft9S80zyAW5492+uo9k=",
            "content_base64sha512": "V8igkWpu7+EpQ2XVjt5MrhKLZjHKS4AHofm2SM3S5Amkq7lMMK86NhV6QfdpxtEsXSXm8bRvn3TdobM1d8Zynw==",
            "content_md5": "9b061e11f39306ad22a1657fc839e30a",
            "content_sha1": "d9c799d8fceb351f8df292be649dd16ab78e9894",
            "content_sha256": "db06762ebbae79115f1add21a46c8b281f347edf52f34cf2016e78f76faea3d9",
            "content_sha512": "57c8a0916a6eefe1294365d58ede4cae128b6631ca4b8007a1f9b648cdd2e409a4abb94c30af3a36157a41f769c6d12c5d25e6f1b46f9f74dda1b33577c6729f",
            "directory_permission": "0777",
